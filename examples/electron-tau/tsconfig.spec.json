{
  "extends": "./tsconfig.json",
  "include": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "e2e/**/*.ts",
    "e2e/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "vitest.config.ts",
    "playwright.config.ts"
  ],
  "compilerOptions": {
    "outDir": "./out-tsc/spec",
    "lib": ["DOM", "DOM.Iterable", "ES2024"],
    "types": ["node", "vitest/globals"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2024",
    "paths": {
      "package.json": ["./package.json"],
      "#main/*": ["./src/main/*"],
      "#preload/*": ["./src/preload/*"],
      "#renderer/*": ["./src/renderer/*"],
      "#shared/*": ["./src/shared/*"]
    }
  }
}
