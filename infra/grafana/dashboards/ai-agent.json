{
  "uid": "tau-ai-agent",
  "title": "AI Agent",
  "tags": ["tau", "ai", "llm", "genai"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "title": "Token Usage (Input / Output)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(gen_ai_client_token_usage_sum{service_name=\"tau-api\"}[5m])) by (gen_ai_token_type, gen_ai_request_model)",
          "legendFormat": "{{gen_ai_request_model}} {{gen_ai_token_type}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "Estimated Cost ($/hr)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(gen_ai_client_cost_total{service_name=\"tau-api\"}[1h]))",
          "legendFormat": "$/hr"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 5, "color": "yellow" },
              { "value": 20, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "title": "Model Usage Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "sum(gen_ai_client_token_usage_sum{service_name=\"tau-api\"}) by (gen_ai_request_model)",
          "legendFormat": "{{gen_ai_request_model}}"
        }
      ]
    },
    {
      "title": "Operation Duration (p50 / p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(gen_ai_client_operation_duration_bucket{service_name=\"tau-api\"}[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(gen_ai_client_operation_duration_bucket{service_name=\"tau-api\"}[5m])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Tool Invocations",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(gen_ai_tool_invocations_total{service_name=\"tau-api\"}[5m])) by (gen_ai_tool_name)",
          "legendFormat": "{{gen_ai_tool_name}}"
        }
      ]
    }
  ],
  "schemaVersion": 39
}
