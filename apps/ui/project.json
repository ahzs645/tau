{
  "name": "ui",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/ui",
  "projectType": "application",
  "tags": ["scope:ui", "type:app"],
  "targets": {
    "build": {
      "dependsOn": ["copy-assets", "^copy-assets"],
      "outputs": ["{projectRoot}/build"],
      "options": {
        "env": {
          "NODE_OPTIONS": "--max-old-space-size=8192"
        }
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "continuous": true,
      "dependsOn": ["build"],
      "options": {
        "cwd": "{projectRoot}",
        "command": "react-router-serve build/server/index.js"
      },
      "configurations": {},
      "parallelism": true
    },
    "typegen": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["{projectRoot}/app/**/*.tsx", "{projectRoot}/app/**/*.ts", "{projectRoot}/react-router.config.ts"],
      "outputs": ["{projectRoot}/.react-router/types/**"],
      "options": {
        "command": "react-router typegen",
        "cwd": "{projectRoot}"
      }
    },
    "typecheck": {
      "dependsOn": ["typegen"]
    },
    "sourcemaps": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "npx -y @posthog/cli sourcemap inject --directory {projectRoot}/build/client --project tau-ui",
          "npx -y @posthog/cli sourcemap upload --directory {projectRoot}/build/client --delete-after"
        ],
        "parallel": false
      }
    }
  }
}
