{
  "name": "runtime",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/runtime",
  "projectType": "library",
  "tags": ["scope:shared", "type:lib"],
  "targets": {
    "test": {
      "dependsOn": ["copy-assets"]
    },
    "benchmark": {
      "command": "tsx --require ./scripts/cjs-compat.cjs scripts/benchmark-kernels.mts",
      "options": {
        "cwd": "{projectRoot}"
      }
    },
    "wasm-inspect": {
      "command": "tsx scripts/wasm-inspect.mts",
      "options": {
        "cwd": "{projectRoot}"
      }
    },
    "build-matrix": {
      "command": "tsx scripts/build-matrix-report.mts",
      "options": {
        "cwd": "{projectRoot}"
      }
    },
    "compare-benchmarks": {
      "command": "tsx scripts/compare-benchmarks.mts",
      "options": {
        "cwd": "{projectRoot}"
      }
    },
    "size": {
      "command": "size-limit",
      "options": {
        "cwd": "{projectRoot}"
      },
      "dependsOn": ["build"]
    }
  }
}
