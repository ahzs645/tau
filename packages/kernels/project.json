{
  "name": "kernels",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/kernels",
  "projectType": "library",
  "tags": ["scope:shared", "type:lib"],
  "targets": {
    "build": {
      "outputs": ["{projectRoot}/src/assets/**"]
    },
    "test": {
      "dependsOn": ["copy-assets"]
    },
    "benchmark": {
      "command": "tsx --require ./scripts/cjs-compat.cjs scripts/benchmark-kernels.mts",
      "options": {
        "cwd": "{projectRoot}"
      }
    }
  }
}
